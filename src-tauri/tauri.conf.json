{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Textree",
  "version": "0.2.3",
  "identifier": "com.iyulab.textree",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Textree",
        "width": 1100,
        "height": 740,
        "minWidth": 640,
        "minHeight": 480,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "resources/canopy/": "canopy/",
      "resources/host/": "host/"
    },
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      },
      "signCommand": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/sign-windows.ps1 %1"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ3Nzc4NkI0RDI2NjA0QzgKUldUSUJHYlN0SVozMTZyVU1XMjlVc0I5R0J3dGxpejR2WUdrd21FMHlHSlFOM3ZSRGhkR29Cb1EK",
      "endpoints": [
        "https://github.com/iyulab/textree/releases/latest/download/latest.json"
      ]
    }
  }
}
